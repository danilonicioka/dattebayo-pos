{
    "compilerOptions": {
        "composite": true,
        "declaration": true,
        "declarationMap": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "isolatedModules": true,
        "moduleResolution": "bundler",
        "preserveWatchOutput": true,
        "skipLibCheck": true,
        "strict": true,
        "strictPropertyInitialization": false
    }
}