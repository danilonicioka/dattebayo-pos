{
  "name": "api",
  "version": "1.0.0",
  "description": "Dattebayo POS API - Hono",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "start:migrate:prod": "npx prisma migrate deploy && npx prisma db seed && node dist/main.js",
    "prisma:generate": "prisma generate",
    "lint": "eslint \"src/**/*.ts\" --fix"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@prisma/client": "^5.22.0",
    "hono": "^4.6.20",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
